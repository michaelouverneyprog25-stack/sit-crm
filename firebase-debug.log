||\n        resource.data.seller == getUserEmail()\n      );\n      allow update: if isSignedIn() && (\n        isAdminOrMaster() ||\n        (isStoreManager() && sameStore(resource.data.storeName) && sameStore(request.resource.data.storeName))\n      );\n      allow delete: if isSignedIn() && isAdminOrMaster();\n    }\n\n    // Legacy metas collection: authenticated users can read/write while data migrates to goals\n    match /metas/{metaId} {\n      allow create, read, update, delete: if isSignedIn();\n    }\n\n    // Goals collection: persistent CRM goals and realized values\n    match /goals/{goalId} {\n      allow create: if isSignedIn() && (\n        isAdminOrMaster() ||\n        ownsGoal(request.resource.data) ||\n        managerCanAccessGoal(request.resource.data)\n      );\n      allow read: if isSignedIn() && (\n        isAdminOrMaster() ||\n        ownsGoal(resource.data) ||\n        managerCanAccessGoal(resource.data)\n      );\n      allow update: if isSignedIn() && (\n        isAdminOrMaster() ||\n        ownsGoal(resource.data) ||\n        (managerCanAccessGoal(resource.data) && managerCanAccessGoal(request.resource.data))\n      );\n      allow delete: if isSignedIn() && (\n        isAdminOrMaster() ||\n        managerCanAccessGoal(resource.data)\n      );\n    }\n\n    // Commission rules: upgrade commission table managed by admins\n    match /commissionRules/{ruleId} {\n      allow read: if isSignedIn() && (isAdminOrMaster() || isStoreManager());\n      allow create, update, delete: if isSignedIn() && isAdmin();\n    }\n\n    // Import history and administrative spreadsheet ingestion\n    match /importHistory/{docId} {\n      allow read, create, update, delete: if isSignedIn() && isAdmin();\n    }\n\n    match /clientes/{docId} {\n      allow read, create, update, delete: if isSignedIn() && isAdmin();\n    }\n\n    // Internal support base: every authenticated user can report errors; only ADM can inspect or resolve.\n    match /system_errors/{docId} {\n      allow create: if isSignedIn();\n      allow read, update, delete: if isSignedIn() && isAdmin();\n    }\n\n    // Stores: used by goals, reports, user management, and fiber city selectors\n    match /stores/{storeId} {\n      allow read: if isSignedIn() && (\n        isAdminOrMaster() ||\n        (isStoreManager() && sameStore(resource.data.name))\n      );\n      allow create, update, delete: if isSignedIn() && isAdminOrMaster();\n    }\n\n    // Fiber viability collections may vary by import/source name. Authenticated users can consult them.\n    match /viabilidade_fibra/{docId} {\n      allow read: if isSignedIn();\n      allow create, update, delete: if isSignedIn() && isAdmin();\n    }\n\n    match /fiberCoverage/{docId} {\n      allow read: if isSignedIn();\n      allow create, update, delete: if isSignedIn() && isAdmin();\n    }\n\n    match /fiberViability/{docId} {\n      allow read: if isSignedIn();\n      allow create, update, delete: if isSignedIn() && isAdmin();\n    }\n\n    match /fiberCoverageCities/{docId} {\n      allow read: if isSignedIn();\n      allow create, update, delete: if isSignedIn() && isAdmin();\n    }\n\n    match /fiberCities/{docId} {\n      allow read: if isSignedIn();\n      allow create, update, delete: if isSignedIn() && isAdmin();\n    }\n\n    match /cidadesFibra/{docId} {\n      allow read: if isSignedIn();\n      allow create, update, delete: if isSignedIn() && isAdmin();\n    }\n\n    match /viabilidadeFibra/{docId} {\n      allow read: if isSignedIn();\n      allow create, update, delete: if isSignedIn() && isAdmin();\n    }\n\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function getUserEmail() {\n      return request.auth.token.email;\n    }\n\n    function getUserRole() {\n      return request.auth.token.role;\n    }\n\n    function isAdmin() {\n      return isSignedIn() && getUserRole() == 'Administrador';\n    }\n\n    function isAdminOrMaster() {\n      return isSignedIn() && (\n        getUserRole() == 'Administrador' ||\n        getUserRole() == 'Gestor Master'\n      );\n    }\n\n    function isStoreManager() {\n      return isSignedIn() && getUserRole() == 'Gerente';\n    }\n\n    function currentUserProfile() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n    }\n\n    function currentUserStore() {\n      return currentUserProfile().storeName;\n    }\n\n    function sameStore(storeName) {\n      return storeName is string && currentUserStore() is string && storeName == currentUserStore();\n    }\n\n    function ownsGoal(goal) {\n      return goal.userId == request.auth.uid;\n    }\n\n    function managerCanAccessGoal(goal) {\n      return isStoreManager() && (\n        sameStore(goal.storeName) ||\n        (\n          goal.userId is string &&\n          exists(/databases/$(database)/documents/users/$(goal.userId)) &&\n          get(/databases/$(database)/documents/users/$(goal.userId)).data.storeName == currentUserStore()\n        )\n      );\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-24T19:00:25.766079Z","metadata":{"services":["cloud.firestore"]}}
