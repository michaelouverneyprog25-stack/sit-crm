# Firebase Admin seed environment variables
# Copy this file to .env and fill in your real values.

FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json
# Optional for production hosting. Paste the full service account JSON as one line.
SERVICE_ACCOUNT_JSON=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Administrador

VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
VITE_API_URL=http://localhost:4000

# Use in production to restrict which frontend domains can call the backend.
# Example: ALLOWED_ORIGINS=https://intercell-crm.web.app,https://crm.sualoja.com.br
ALLOWED_ORIGINS=
