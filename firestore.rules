rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: admins/masters can see all; managers only see users from their own store.
    match /users/{userId} {
      allow read: if isSignedIn() && (
        isAdminOrMaster() ||
        request.auth.uid == userId ||
        (isStoreManager() && sameStore(resource.data.storeName))
      );
      allow write: if isSignedIn() && (
        isAdminOrMaster() ||
        request.auth.uid == userId ||
        (isStoreManager() && sameStore(request.resource.data.storeName))
      );
    }

    // Vendas collection: managers are restricted to their own store; admins/masters can read all.
    match /vendas/{saleId} {
      allow create: if isSignedIn() && (
        isAdminOrMaster() ||
        (isStoreManager() && sameStore(request.resource.data.storeName)) ||
        request.resource.data.seller == getUserEmail()
      );
      allow read: if isSignedIn() && (
        isAdminOrMaster() ||
        (isStoreManager() && sameStore(resource.data.storeName)) ||
        resource.data.seller == getUserEmail()
      );
      allow update: if isSignedIn() && (
        isAdminOrMaster() ||
        (isStoreManager() && sameStore(resource.data.storeName) && sameStore(request.resource.data.storeName))
      );
      allow delete: if isSignedIn() && isAdminOrMaster();
    }

    // Portabilidades collection: similar access rules for seller operations
    match /portabilidades/{itemId} {
      allow create: if isSignedIn() && request.resource.data.seller == getUserEmail();
      allow read: if isSignedIn() && (
        isAdminOrMaster() ||
        (isStoreManager() && sameStore(resource.data.storeName)) ||
        resource.data.seller == getUserEmail()
      );
      allow update: if isSignedIn() && (
        isAdminOrMaster() ||
        (isStoreManager() && sameStore(resource.data.storeName) && sameStore(request.resource.data.storeName))
      );
      allow delete: if isSignedIn() && isAdminOrMaster();
    }

    // Legacy metas collection: authenticated users can read/write while data migrates to goals
    match /metas/{metaId} {
      allow create, read, update, delete: if isSignedIn();
    }

    // Goals collection: persistent CRM goals and realized values
    match /goals/{goalId} {
      allow create: if isSignedIn() && (
        isAdminOrMaster() ||
        ownsGoal(request.resource.data) ||
        managerCanAccessGoal(request.resource.data)
      );
      allow read: if isSignedIn() && (
        isAdminOrMaster() ||
        ownsGoal(resource.data) ||
        managerCanAccessGoal(resource.data)
      );
      allow update: if isSignedIn() && (
        isAdminOrMaster() ||
        ownsGoal(resource.data) ||
        (managerCanAccessGoal(resource.data) && managerCanAccessGoal(request.resource.data))
      );
      allow delete: if isSignedIn() && (
        isAdminOrMaster() ||
        managerCanAccessGoal(resource.data)
      );
    }

    // Commission rules: upgrade commission table managed by admins
    match /commissionRules/{ruleId} {
      allow read: if isSignedIn() && (isAdminOrMaster() || isStoreManager());
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    // Stores: used by goals, reports, user management, and fiber city selectors
    match /stores/{storeId} {
      allow read: if isSignedIn() && (
        isAdminOrMaster() ||
        (isStoreManager() && sameStore(resource.data.name))
      );
      allow create, update, delete: if isSignedIn() && isAdminOrMaster();
    }

    // Fiber viability collections may vary by import/source name. Authenticated users can consult them.
    match /fiberCoverage/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /fiberViability/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /fiberCoverageCities/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /fiberCities/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /cidadesFibra/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /viabilidadeFibra/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserEmail() {
      return request.auth.token.email;
    }

    function getUserRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'Administrador';
    }

    function isAdminOrMaster() {
      return isSignedIn() && (
        getUserRole() == 'Administrador' ||
        getUserRole() == 'Gestor Master'
      );
    }

    function isStoreManager() {
      return isSignedIn() && getUserRole() == 'Gerente';
    }

    function currentUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function currentUserStore() {
      return currentUserProfile().storeName;
    }

    function sameStore(storeName) {
      return storeName is string && currentUserStore() is string && storeName == currentUserStore();
    }

    function ownsGoal(goal) {
      return goal.userId == request.auth.uid;
    }

    function managerCanAccessGoal(goal) {
      return isStoreManager() && (
        sameStore(goal.storeName) ||
        (
          goal.userId is string &&
          exists(/databases/$(database)/documents/users/$(goal.userId)) &&
          get(/databases/$(database)/documents/users/$(goal.userId)).data.storeName == currentUserStore()
        )
      );
    }
  }
}
